# ==================================================
# Lisory — Environment Variables
# Copy to .env and fill in production values
# ==================================================

# Database (required)
DB_PASSWORD=changeme

# JWT (required — min 32 chars)
JWT_SECRET=changeme-min-32-chars-for-production

# CORS (default: production domain)
# CORS_ALLOWED_ORIGINS=https://lisory.com.br

# Melhor Envio (https://docs.melhorenvio.com.br)
MELHOR_ENVIO_CLIENT_ID=your-client-id
MELHOR_ENVIO_CLIENT_SECRET=your-client-secret
# MELHOR_ENVIO_API_URL=https://api.melhorenvio.com.br
# MELHOR_ENVIO_CALLBACK_URL=https://lisory.com.br/api/integrations/melhor-envio/oauth/callback

# Asaas (sandbox: https://sandbox.asaas.com/api/v3, production: https://api.asaas.com/api/v3)
# Get API key at https://sandbox.asaas.com (sandbox) or https://www.asaas.com (production)
ASAAS_API_KEY=
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_REDIRECT_URL=https://lisory.com.br/confirmation

# Frontend
NEXT_PUBLIC_API_URL=https://api.lisory.com.br
