# ==================================================
# Lisory — Environment Variables
# Copy to .env and fill in production values
# ==================================================

# Database (required)
DB_PASSWORD=changeme

# JWT (required — min 32 chars)
JWT_SECRET=changeme-min-32-chars-for-production

# CORS (default: production domain)
# CORS_ALLOWED_ORIGINS=https://lisory.com.br

# Melhor Envio (https://docs.melhorenvio.com.br)
MELHOR_ENVIO_CLIENT_ID=26942
MELHOR_ENVIO_CLIENT_SECRET=ZP7Wd00rrtODcyvvQ71qFnMDW6AMVWYjboBOgcrE
# MELHOR_ENVIO_API_URL=https://melhorenvio.com.br
# MELHOR_ENVIO_CALLBACK_URL=https://lisory.com.br/api/integrations/melhor-envio/oauth/callback

# InfinitePay Checkout (no auth required — only handle needed)
# https://www.infinitepay.io/checkout
INFINITEPAY_HANDLE=lisory
# INFINITEPAY_REDIRECT_URL=https://lisory.com.br/checkout/success
# INFINITEPAY_WEBHOOK_URL=https://lisory.com.br/webhooks/infinitepay

# Frontend
NEXT_PUBLIC_API_URL=https://api.lisory.com.br
