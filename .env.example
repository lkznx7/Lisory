# Database
DB_URL=jdbc:postgresql://localhost:5432/lisory
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_DRIVER=org.postgresql.Driver

# JWT (REQUIRED - no default)
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRATION=86400000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Melhor Envio (https://docs.melhorenvio.com.br)
MELHOR_ENVIO_CLIENT_ID=your-client-id
MELHOR_ENVIO_CLIENT_SECRET=your-client-secret
MELHOR_ENVIO_ACCESS_TOKEN=your-access-token
MELHOR_ENVIO_REFRESH_TOKEN=your-refresh-token
MELHOR_ENVIO_API_URL=https://sandbox.melhorenvio.com.br
MELHOR_ENVIO_USER_AGENT=Lisory/1.0
MELHOR_ENVIO_CALLBACK_URL=http://localhost:8080/api/integrations/melhor-envio/oauth/callback
MELHOR_ENVIO_SCOPES=cart-read cart-write orders-read shipping-calculate shipping-cancel shipping-checkout shipping-companies shipping-generate shipping-preview shipping-print shipping-share shipping-tracking

# InfinitePay Checkout (https://ajuda.infinitepay.io)
INFINITEPAY_HANDLE=your-infinite-tag
INFINITEPAY_CHECKOUT_API_URL=https://api.checkout.infinitepay.io
INFINITEPAY_WEBHOOK_SECRET=your-webhook-secret
INFINITEPAY_REDIRECT_URL=http://localhost:3000/checkout/success
INFINITEPAY_WEBHOOK_URL=http://localhost:8080/webhooks/infinitepay
INFINITEPAY_CLIENT_ID=your-client-id
